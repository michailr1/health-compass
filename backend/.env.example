# Health Compass Backend — Environment Configuration
# Copy to /etc/health-compass/backend.env for production.
# Never commit secrets to Git.

# Service
SERVICE_NAME=health-compass-api
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=127.0.0.1
PORT=8100

# Database — set both for production; never use "changeme"
# DATABASE_URL=postgresql+psycopg://health_compass_app:<password>@127.0.0.1:5433/health_compass
# DATABASE_MIGRATOR_URL=postgresql+psycopg://health_compass_migrator:<password>@127.0.0.1:5433/health_compass

# Build commit — injected at deploy time
# BUILD_COMMIT=

# Direct Google OIDC
OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=<google-oauth-client-id>
# OIDC_CLIENT_SECRET=<google-oauth-client-secret>
# OIDC_AUDIENCE=<google-oauth-client-id>
# OIDC_REDIRECT_URI=https://health.funti.cc/api/auth/callback

# Session
# SESSION_COOKIE_NAME=hc_session
# SESSION_TTL_SECONDS=43200
# FRONTEND_URL=https://health.funti.cc/app

# Email Magic Links
EMAIL_AUTH_ENABLED=false
# MAGIC_LINK_CONSUME_URL=https://health.funti.cc/api/auth/email/consume
# MAGIC_LINK_TTL_SECONDS=900
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USERNAME=<smtp-login>
# SMTP_PASSWORD=<smtp-password>
# SMTP_FROM_EMAIL=health@funti.cc
# SMTP_STARTTLS=true
# SMTP_USE_SSL=false

# Account linking — required true outside development
ACCOUNT_LINKING_ENABLED=false
# ACCOUNT_LINK_INTENT_TTL_SECONDS=600
# ACCOUNT_LINK_COOKIE_NAME=hc_account_link

# HC-017 encrypted document pipeline
# Still development/test only. Production startup rejects true until storage,
# scanner, renderer, OCR, reverse-proxy and temporary-spool controls are approved.
DOCUMENT_UPLOAD_ENABLED=false
DOCUMENT_STORAGE_BACKEND=local_encrypted
DOCUMENT_STORAGE_ROOT=/tmp/health-compass-documents
DOCUMENT_MAX_BYTES=20971520
DOCUMENT_MAX_IMAGE_PIXELS=25000000
DOCUMENT_MIN_FREE_BYTES=536870912
DOCUMENT_ENCRYPTION_ACTIVE_KEY_ID=dev-document-key
DOCUMENT_CREDENTIALS_DIRECTORY=/tmp/health-compass-document-credentials

# Development/test quota defaults. Production values require measured capacity.
DOCUMENT_PROFILE_MAX_BYTES=536870912
DOCUMENT_GLOBAL_MAX_BYTES=10737418240
DOCUMENT_PROFILE_MAX_DOCUMENTS=100
DOCUMENT_PROFILE_MAX_QUEUED_JOBS=20

# Restricted scanner worker. Use a separate NOBYPASSRLS database login.
# DOCUMENT_WORKER_DATABASE_URL=postgresql+psycopg://health_compass_worker:<password>@127.0.0.1:5433/health_compass
DOCUMENT_SCANNER_SOCKET=/run/clamav/clamd.ctl
DOCUMENT_SCANNER_TIMEOUT_SECONDS=60
DOCUMENT_SCANNER_MAX_SIGNATURE_AGE_HOURS=48
DOCUMENT_WORKER_LEASE_SECONDS=300
DOCUMENT_WORKER_MAX_ATTEMPTS=5

# Restricted safe-renderer worker.
# DOCUMENT_RENDERER_DATABASE_URL=postgresql+psycopg://health_compass_renderer:<password>@127.0.0.1:5433/health_compass
DOCUMENT_PDFINFO_PATH=/usr/bin/pdfinfo
DOCUMENT_PDFTOCAIRO_PATH=/usr/bin/pdftocairo
DOCUMENT_MAGICK_PATH=/usr/bin/magick
DOCUMENT_RENDER_TIMEOUT_SECONDS=30
DOCUMENT_RENDER_CPU_SECONDS=20
DOCUMENT_RENDER_MEMORY_BYTES=536870912
DOCUMENT_RENDER_MAX_OUTPUT_BYTES=52428800
DOCUMENT_RENDER_MAX_PAGES=50
DOCUMENT_RENDER_DPI=150
DOCUMENT_RENDER_LEASE_SECONDS=300
DOCUMENT_RENDER_MAX_ATTEMPTS=3

# Restricted storage reconciler.
# DOCUMENT_RECONCILER_DATABASE_URL=postgresql+psycopg://health_compass_reconciler:<password>@127.0.0.1:5433/health_compass
DOCUMENT_ORPHAN_GRACE_SECONDS=3600
DOCUMENT_ORPHAN_DELETE_SECONDS=604800

# HC-017 D1 restricted local OCR worker.
# Production upload remains disabled; these values are repository/test defaults.
# DOCUMENT_OCR_DATABASE_URL=postgresql+psycopg://health_compass_ocr_worker:<password>@127.0.0.1:5433/health_compass
DOCUMENT_TESSERACT_PATH=/usr/bin/tesseract
DOCUMENT_TESSDATA_DIRECTORY=/usr/share/tesseract-ocr/5/tessdata
DOCUMENT_OCR_LANGUAGE_SPEC=rus+eng
DOCUMENT_OCR_PSM=6
DOCUMENT_OCR_TIMEOUT_SECONDS=30
DOCUMENT_OCR_CPU_SECONDS=20
DOCUMENT_OCR_MEMORY_BYTES=536870912
DOCUMENT_OCR_MAX_OUTPUT_BYTES=10485760
DOCUMENT_OCR_MAX_ROWS=100000
DOCUMENT_OCR_MAX_CANDIDATES=5000
DOCUMENT_OCR_MAX_CANDIDATE_CHARS=4000
DOCUMENT_OCR_MAX_CANDIDATE_WORDS=200
DOCUMENT_OCR_LEASE_SECONDS=300
DOCUMENT_OCR_MAX_ATTEMPTS=3

# CORS
# CORS_ORIGINS=["https://health.funti.cc"]

# Temporary local integration tests only; must be false in production
ALLOW_DEV_AUTH=false
