# Health Compass Backend — Environment Configuration
# Copy to /etc/health-compass/backend.env for production.
# Never commit secrets to Git.

# Service
SERVICE_NAME=health-compass-api
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=127.0.0.1
PORT=8100

# Database — set both for production; never use "changeme"
# DATABASE_URL=postgresql+psycopg://health_compass_app:<password>@127.0.0.1:5433/health_compass
# DATABASE_MIGRATOR_URL=postgresql+psycopg://health_compass_migrator:<password>@127.0.0.1:5433/health_compass

# Build commit — injected at deploy time
# BUILD_COMMIT=

# Direct Google OIDC
OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=<google-oauth-client-id>
# OIDC_CLIENT_SECRET=<google-oauth-client-secret>
# OIDC_AUDIENCE=<google-oauth-client-id>
# OIDC_REDIRECT_URI=https://health.funti.cc/api/auth/callback

# Session
# SESSION_COOKIE_NAME=hc_session
# SESSION_TTL_SECONDS=43200
# FRONTEND_URL=https://health.funti.cc/app

# Email Magic Links
EMAIL_AUTH_ENABLED=false
# MAGIC_LINK_CONSUME_URL=https://health.funti.cc/api/auth/email/consume
# MAGIC_LINK_TTL_SECONDS=900
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USERNAME=<smtp-login>
# SMTP_PASSWORD=<smtp-password>
# SMTP_FROM_EMAIL=health@funti.cc
# SMTP_STARTTLS=true
# SMTP_USE_SSL=false

# CORS
# CORS_ORIGINS=["https://health.funti.cc"]

# Temporary local integration tests only; must be false in production
ALLOW_DEV_AUTH=false
