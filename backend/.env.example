# Health Compass Backend — Environment Configuration
# Copy to /etc/health-compass/backend.env for production.
# Never commit secrets to Git.

# Service
SERVICE_NAME=health-compass-api
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=127.0.0.1
PORT=8100

# Database — set both for production; never use "changeme"
# DATABASE_URL=postgresql+psycopg://health_compass_app:<password>@127.0.0.1:5433/health_compass
# DATABASE_MIGRATOR_URL=postgresql+psycopg://health_compass_migrator:<password>@127.0.0.1:5433/health_compass

# Build commit — injected at deploy time
# BUILD_COMMIT=

# Future OIDC (not yet active)
# OIDC_ISSUER=https://authentik.example.com/application/o/health-compass/
# OIDC_CLIENT_ID=health-compass
# OIDC_AUDIENCE=account
